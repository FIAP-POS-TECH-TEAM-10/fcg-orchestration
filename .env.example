# Copie para .env e preencha. NÃO commitar o .env real.

# PAT do GitHub com scope read:packages (restaura o pacote FCGames.IntegrationEvents
# durante o build das imagens).
NUGET_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Chave de assinatura do JWT — DEVE ser idêntica nos 3 serviços que usam JWT
# (users emite; catalog e payments validam). Mínimo 32 chars.
JWT_KEY=ChaveSegredo12345671212121321341231231890

# Credenciais do RabbitMQ (default guest/guest).
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
